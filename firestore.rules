rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function protectedStatsUnchanged() {
      return request.resource.data.credits == resource.data.credits &&
          request.resource.data.wins == resource.data.wins &&
          request.resource.data.losses == resource.data.losses &&
          request.resource.data.score == resource.data.score &&
          request.resource.data.rankScore == resource.data.rankScore &&
          request.resource.data.totalGames == resource.data.totalGames;
    }

    function allowedSelfUpdateKeys() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'displayName',
        'cardAvatarRank',
        'cardAvatarSuit',
        'hasCustomProfile',
        'updatedAt',
        'lastLoginAt',
        'email',
        'photoUrl',
        'avatarUrl',
        'isRegistered',
      ]);
    }

    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) && protectedStatsUnchanged() && allowedSelfUpdateKeys();
      allow delete: if request.auth.token.admin == true;
    }

    // TODO: Durcir les autres collections selon les besoins métier.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
