rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin';
    }

    function isRegisteredProfile() {
      return resource.data.isRegistered == true;
    }

    match /user_profiles/{uid} {
      allow read: if isSignedIn() && (isRegisteredProfile() || isOwner(uid) || isAdmin());
      allow create: if isOwner(uid);

      // Permet aux joueurs de maintenir leur propre profil (pseudo, avatar, crédits, score)
      // et à l'admin de faire des corrections serveur.
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /duel_games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.hostId == request.auth.uid &&
        request.resource.data.players is list &&
        request.auth.uid in request.resource.data.players;

      // Uniquement les joueurs de la partie (ou admin) peuvent modifier l'état d'une partie.
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid in resource.data.players
      );

      allow delete: if isAdmin();

      match /actions/{actionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/duel_games/$(gameId)).data.players
        );
        allow update, delete: if false;
      }

      match /chat_messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/duel_games/$(gameId)).data.players
        );
        allow update, delete: if false;
      }
    }

    match /match_results/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /admin_transactions/{txId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
