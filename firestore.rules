    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isSignedIn();
      allow delete: if request.auth.token.admin == true;
    }

    match /duel_games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.players ||
        (resource.data.players.size() < 2 && resource.data.status == 'waiting')
      );
      allow delete: if false;
    }

    match /duel_games/{gameId}/actions/{actionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/duel_games/$(gameId)).data.players;
      allow update, delete: if false;
    }

    match /duel_games/{gameId}/chat_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if false;
    }

